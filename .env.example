# =============================================================================
# Video2Skill — variables d'environnement. Copie vers .env.local et remplis.
#
# WEB APP (Vercel) : DATABASE_URL, DIRECT_URL, AUTH_*, BLOB_READ_WRITE_TOKEN,
#   GITHUB_WORKER_*, STRIPE_*, CREDITS_*, NEXT_PUBLIC_*.
# WORKER (secrets GitHub Actions) : DATABASE_URL (pooler session),
#   BLOB_READ_WRITE_TOKEN, OPENAI_API_KEY, ANTHROPIC_API_KEY.
# Ne jamais committer de vraies clés.
# =============================================================================

# --- IA (worker) -------------------------------------------------------------
OPENAI_API_KEY=sk-...
# Optionnelle : requise seulement si un provider ci-dessous vaut "anthropic".
ANTHROPIC_API_KEY=sk-ant-...

# Providers : openai | anthropic
TRANSCRIPTION_PROVIDER=openai
VISION_PROVIDER=openai
SYNTHESIS_PROVIDER=openai

# Modèles (configurables — ils évoluent). Sonnet par défaut : sur ~180 captures
# par vidéo, Opus coûterait plus cher en API que la vidéo ne rapporte en crédits.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_VISION_MODEL=gpt-4o
ANTHROPIC_VISION_MODEL=claude-sonnet-5
ANTHROPIC_SYNTHESIS_MODEL=claude-sonnet-5

# Réglages pipeline (worker). Défauts équilibrés-rapides ; monte
# MAX_VISION_FRAMES pour + de qualité, baisse VISION_CONCURRENCY si ton
# compte IA sature (429).
FRAME_INTERVAL_SEC=5
SCENE_THRESHOLD=0.3
AUDIO_CHUNK_SEC=600
MAX_VISION_FRAMES=60
VISION_CONCURRENCY=4
API_TIMEOUT_MS=90000
API_MAX_RETRIES=2
OCR_LANGS=fra+eng

# --- Base de données (Supabase Postgres) -------------------------------------
# Supabase → ton projet → bouton « Connect » → Connection string.
# App serverless (Vercel) : pooler TRANSACTION (port 6543) + pgbouncer=true :
DATABASE_URL=postgresql://postgres.PROJET:MOT_DE_PASSE@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Migrations (npm run db:push) + worker : pooler SESSION (port 5432 — IPv4) :
DIRECT_URL=postgresql://postgres.PROJET:MOT_DE_PASSE@aws-0-eu-west-3.pooler.supabase.com:5432/postgres
# ⚠️ N'utilise pas l'hôte direct db.PROJET.supabase.co : IPv6 uniquement sur le
# plan gratuit (inaccessible depuis GitHub Actions et beaucoup de réseaux).
# En local (docker compose) : mets la même URL locale dans les deux variables.

# --- Auth.js / Google OAuth --------------------------------------------------
# Génère le secret avec : npx auth secret
AUTH_SECRET=remplace-par-une-longue-chaine-aleatoire
AUTH_GOOGLE_ID=xxxxxxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-...
# Vercel définit l'URL automatiquement. Pour un autre hébergeur :
# AUTH_URL=https://ton-app.example.com

# --- Stockage blob (Vercel Blob) ---------------------------------------------
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
MAX_UPLOAD_MB=2048

# --- Worker GitHub Actions (déclenchement automatique) -----------------------
# PAT fine-grained limité à CE repo, permission « Contents: Read and write ».
# Sans ces 2 variables : pas de réveil instantané, les jobs attendent le cron
# de secours du workflow (toutes les 6 h).
GITHUB_WORKER_TOKEN=github_pat_...
GITHUB_WORKER_REPO=Oxidoo/Video2Skill

# --- Stripe (achat de crédits) -----------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Crédits / tarification --------------------------------------------------
CREDITS_PER_MINUTE=1
SIGNUP_BONUS_CREDITS=10
# Copie visible côté client (doit être égale à CREDITS_PER_MINUTE) :
NEXT_PUBLIC_CREDITS_PER_MINUTE=1

# URL publique de l'app (redirections Stripe)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Worker : mode et réglages -----------------------------------------------
# WORKER_MODE=drain → traite la file puis s'arrête (GitHub Actions).
# Par défaut : boucle de polling infinie (conteneur / PC local).
WORKER_POLL_MS=5000
# WORKER_TMP_DIR=/tmp
