# =============================================================================
# Video2Skill environment. Copy to .env.local and fill in.
# The WEB APP (Vercel) needs: DATABASE_URL, AUTH_*, BLOB_READ_WRITE_TOKEN,
#   STRIPE_*, NEXT_PUBLIC_*, CREDITS_*.
# The WORKER (container) needs: DATABASE_URL, BLOB_READ_WRITE_TOKEN,
#   OPENAI_API_KEY, ANTHROPIC_API_KEY, pipeline tuning, CREDITS_PER_MINUTE.
# Never commit real keys.
# =============================================================================

# --- AI providers (worker) --------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Providers: openai | anthropic
TRANSCRIPTION_PROVIDER=openai
VISION_PROVIDER=anthropic
SYNTHESIS_PROVIDER=anthropic

# Models (keep configurable — they change over time)
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_VISION_MODEL=gpt-4o
ANTHROPIC_VISION_MODEL=claude-opus-4-8
ANTHROPIC_SYNTHESIS_MODEL=claude-opus-4-8

# Pipeline tuning (worker)
FRAME_INTERVAL_SEC=5
SCENE_THRESHOLD=0.3
AUDIO_CHUNK_SEC=600
MAX_VISION_FRAMES=180
OCR_LANGS=fra+eng

# --- Database (Postgres: Neon / Supabase / Vercel Postgres) -----------------
DATABASE_URL=postgresql://user:password@host:5432/video2skill

# --- Auth.js / Google OAuth -------------------------------------------------
# Generate a secret with: npx auth secret
AUTH_SECRET=replace-with-a-long-random-string
AUTH_GOOGLE_ID=xxxxxxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-...
# Vercel sets the URL automatically. For other hosts, set your canonical URL:
# AUTH_URL=https://your-app.example.com

# --- Blob storage (Vercel Blob) ---------------------------------------------
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
MAX_UPLOAD_MB=2048

# --- Stripe (credit purchases) ----------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Credits / pricing ------------------------------------------------------
CREDITS_PER_MINUTE=1
SIGNUP_BONUS_CREDITS=10
# Client-visible copy of the per-minute cost (must match CREDITS_PER_MINUTE):
NEXT_PUBLIC_CREDITS_PER_MINUTE=1

# Public base URL of the app (used for Stripe success/cancel redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Worker -----------------------------------------------------------------
WORKER_POLL_MS=5000
# WORKER_TMP_DIR=/tmp
